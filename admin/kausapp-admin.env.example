# Copy to kausapp-admin.env and fill ADMIN_SECRET (must match the Cloudflare Pages
# ADMIN_SECRET set via: wrangler pages secret put ADMIN_SECRET). Keep it private (chmod 600).
ADMIN_SECRET=
REPORTS_API=https://kausapp.com/api/reports
# Bind to the droplet's Tailscale IP so the admin is reachable ONLY from the tailnet.
BIND_HOST=100.99.99.75
BIND_PORT=8080
